{
	"extends": "@ljharb/tsconfig",
	"compilerOptions": {
		"target": "ESNext",
		"module": "nodenext",
		"typeRoots": ["./types", "./node_modules/@types", "../../node_modules/@types"],
		"types": ["node"],
		"skipLibCheck": true
	},
	"include": [
		"**/*",
		"../../types/**/*.d.ts"
	],
	"exclude": [
		"**/coverage",
		"node_modules",
		"packages/tests/coverage-loader.mjs"
	]
}
